<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cubeone.scan">

    <!-- Camera Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Storage for photo capture -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Network Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Optional Features -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FLASHLIGHT" />

    <!-- Hardware Requirements -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.flash"
        android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CubeOneScan"
        android:hardwareAccelerated="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="${usesCleartextTraffic}">

        <!-- Main Launcher Activity -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.HomeActivity"
            android:exported="false" />

        <!-- Scanner Activity - CORRECTED PACKAGE to .scanner -->
        <activity
            android:name=".scanner.ScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CubeOneScan"
            android:hardwareAccelerated="true"
            android:keepScreenOn="true" />

        <activity
            android:name=".ui.LicenseResultActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.VehicleResultActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.UserManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.ChangePasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.ApprovalsActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.AuditEventsActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <activity
            android:name=".ui.OperationsDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.CubeOneScan" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>