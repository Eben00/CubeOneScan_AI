PORT=4000
JWT_SECRET=change-me
AUTH_DATA_DIR=/var/data

# Optional tenant config source (Phase 1):
# TENANT_CONFIG_FILE=/etc/secrets/tenant-config.json
# TENANT_CONFIG_JSON={"dealerAliases":{"dealer_ldc":"1257"},"emailDealerMap":{"ldc.admin@cubeonescan.local":"1257"}}
# Optional admin token for Phase 2 tenant config API:
# TENANT_ADMIN_TOKEN=change-me-admin-token

# Optional: normalize legacy/host dealer ids into canonical dealer ids.
# Format: from=to,from2=to2
# Example:
# AUTH_DEALER_ID_ALIASES=dealer_cubeone_connector_onrender_com=1257,dealer_ldc=1257,dealer_drivex=510,dealer_integra=501

# Optional: force specific users into canonical dealer scopes.
# Format: email=dealerId,email2=dealerId
# Example:
# AUTH_EMAIL_DEALER_MAP=ldc.admin@cubeonescan.local=1257,drivex.admin@cubeonescan.local=510,drive.admin@cubeone.local=510,integra.admin@cubeonescan.local=501
