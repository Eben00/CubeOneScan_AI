PORT=8080
API_KEY=change-me
COMMAND_MAX_RETRIES=3
COMMAND_RETRY_DELAY_MS=1200
# CONNECTOR_DATA_DIR=./data

# Optional tenant config source (Phase 1):
# TENANT_CONFIG_FILE=/etc/secrets/tenant-config.json
# TENANT_CONFIG_JSON={"dealerAliases":{"dealer_ldc":"1257"},"emailDealerMap":{"ldc.admin@cubeonescan.local":"1257"}}
#
# TENANT_CONFIG_JSON overrides env for dealerAliases, emailDealerMap, vmgDealerScopes, and both
# Evolve maps when set. Do NOT put numeric stock-feed remaps here (e.g. "510":"208"); use
# DEALER_ID_ALIASES in .env for syndication-only ids — the connector skips alias remap for
# purely numeric tenant ids so Evolve did= / receiving-entity stay aligned with USER_EMAIL_DEALER_MAP.
# Optional CRM provider routing (future-proofing):
# DEFAULT_CRM_PROVIDER=evolvesa
# CRM_PROVIDER_BY_DEALER=1257=evolvesa,510=evolvesa,501=evolvesa
# Optional admin token for Phase 2 tenant config API:
# TENANT_ADMIN_TOKEN=change-me-admin-token
# Optional Phase 5 role split for admin APIs:
# TENANT_ADMIN_EDITOR_ROLES=dealer_principal,tenant_admin_editor
# TENANT_ADMIN_APPROVER_ROLES=dealer_principal,tenant_admin_approver

# Twilio WhatsApp (set these in your real deployment environment)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Vehicle valuation provider — use EITHER key/secret OR username/password
# TRUTRADE_API_KEY=your_apikey_here
# TRUTRADE_API_SECRET=your_apisecret_here
# TRUTRADE_AUTH_USERNAME=
# TRUTRADE_AUTH_PASSWORD=
# TRUTRADE_BASE_URL=https://api.yourvehiclevalue.co.za/api

# EvolveSA CRM (first live adapter: CREATE_LEAD)
# EVOLVESA_BASE_URL=https://your-evolvesa-host
# EVOLVESA_API_KEY=your-evolvesa-bearer-token
# EVOLVESA_TIMEOUT_MS=15000
# Optional: if you want to call the “flows/trigger” endpoint (Cars.co.za style),
# set EVOLVESA_LEAD_TRIGGER_URL to the full URL (including did=...).
# EVOLVESA_LEAD_TRIGGER_URL=https://portal-admin.evolvesa.co.za/flows/trigger/<trigger-id>?did=505
# EVOLVESA_LEAD_RECEIVING_ENTITY_ID=505
# EVOLVESA_LEAD_RECEIVING_ENTITY_NAME=LDC
# EVOLVESA_LEAD_SOURCE=CubeOneScan
# EVOLVESA_LEAD_SOURCE_ID=236
# EVOLVESA_STOCK_SOURCE=CubeOneScan
# EVOLVESA_STOCK_SOURCE_ID=236
# EVOLVESA_DEFAULT_LEAD_ANCILLARY_AREA=Gauteng
# EVOLVESA_DEFAULT_LEAD_USER_AREA=JHB
# Optional stock trigger URL (preferred over API stock endpoint when provided):
# EVOLVESA_STOCK_TRIGGER_URL=https://portal-admin.evolvesa.co.za/flows/trigger/<stock-trigger-id>?did=509
# EVOLVESA_STOCK_ENDPOINT=/api/v1/stocks
# Optional timeline comment endpoint. If blank, connector posts to /leads/leads/<leadId>.
# EVOLVESA_COMMUNICATION_ENDPOINT=/leads/comments

# Consent approval email (POPIA proof flow)
# Render FREE web services block outbound SMTP (25/465/587) — use Brevo HTTPS API instead:
# https://render.com/changelog/free-web-services-will-no-longer-allow-outbound-traffic-to-smtp-ports
# Create an API key in Brevo (Marketing / transactional → API keys). Use xkeysib-... in BREVO_API_KEY.
# BREVO_API_KEY=xkeysib-...
# --- Brevo SMTP (works on paid Render, local dev, or any host that allows outbound 587) ---
# --- Brevo (https://www.brevo.com): verify domain in Brevo, create SMTP key, add Brevo SPF/DKIM in DNS ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-brevo-login-email@example.com
# SMTP_PASS=xkeysib-...   # SMTP & API → SMTP key (not your account password)
# SMTP_FROM_EMAIL=consent@cubeone.co.za   # Must be a verified sender/domain in Brevo
# --- Microsoft 365 / other ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=no-reply@dealer-group.co.za
# SMTP_PASS=app_or_mail_password
# SMTP_FROM_EMAIL=no-reply@dealer-group.co.za
# Optional per-dealer From override:
# CONSENT_FROM_EMAIL_BY_DEALER=509=ldc@dealer-group.co.za,510=drivex@dealer-group.co.za,501=integra@dealer-group.co.za
# Public base URL used in consent approval links:
# CONSENT_LINK_BASE_URL=https://your-connector-host
# CONSENT_DEFAULT_EXPIRY_HOURS=24
# Append-only consent audit events persisted (tail); raise for heavy volume:
# CONSENT_EVENTS_STORE_CAP=50000

# Optional tenant stamping: set this to cubeone-auth JWT_SECRET
# so connector can verify X-User-Token and stamp dealer/branch/user context.
# AUTH_JWT_SECRET=your_auth_jwt_secret
#
# --- Canonical dealer id (VMG / DMS) vs EvolveSA company id ---
# Use one internal dealer id everywhere: cubeone-auth user.dealerId, app X-Dealer-Id,
# USER_EMAIL_DEALER_MAP values, and VMG_DEALER_SCOPES (e.g. LDC VMG id 1257).
# Map that id to EvolveSA CRM (portal company did=509) with:
#   EVOLVESA_LEAD_RECEIVING_ENTITY_MAP=1257=509|LDC Auto
# and EVOLVESA_LEAD_TRIGGER_URL_BY_DEALER keys keyed by 1257, not 509.
# USER_EMAIL_DEALER_MAP uses login email -> same canonical id, e.g. user@ldc=1257
# ENFORCE_TENANT_RINGFENCE=1 (default) requires every mapped user to match X-Dealer-Id.
#
# VMG_STOCK_FEED_URL=http://feeds.vmgsoftware.co.za/xml/f25/feed_1257.xml
# Optional: per-dealer VMG XML when dealers use different feed URLs (Evolve id 510 vs VMG feed id).
# VMG_STOCK_FEED_URL_BY_DEALER=510=http://feeds.vmgsoftware.co.za/xml/f25/feed_510.xml
# VMG_DEALER_SCOPES=1257,501,510
# VMG_TIMEOUT_MS=12000
# VMG_CACHE_TTL_MS=300000
# DEALER_ID_ALIASES=dealer_host_alias=1257

# AutoTrader syndication listings API (optional; used to auto-attach photo URLs for SEND_STOCK_TO_LEAD)
# AUTOTRADER_LISTINGS_URL=https://services.autotrader.co.za/api/syndication/v1.0/listings
# AUTOTRADER_BASIC_AUTH=Basic base64(username:password)
# AUTOTRADER_TIMEOUT_MS=12000
# AUTOTRADER_LISTINGS_CACHE_TTL_MS=300000

