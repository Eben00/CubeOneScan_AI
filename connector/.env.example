PORT=8080
API_KEY=change-me
COMMAND_MAX_RETRIES=3
COMMAND_RETRY_DELAY_MS=1200
# CONNECTOR_DATA_DIR=./data

# Twilio WhatsApp (set these in your real deployment environment)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Vehicle valuation provider — use EITHER key/secret OR username/password
# TRUTRADE_API_KEY=your_apikey_here
# TRUTRADE_API_SECRET=your_apisecret_here
# TRUTRADE_AUTH_USERNAME=
# TRUTRADE_AUTH_PASSWORD=
# TRUTRADE_BASE_URL=https://api.yourvehiclevalue.co.za/api

# EvolveSA CRM (first live adapter: CREATE_LEAD)
# EVOLVESA_BASE_URL=https://your-evolvesa-host
# EVOLVESA_API_KEY=your-evolvesa-bearer-token
# EVOLVESA_TIMEOUT_MS=15000
# Optional: if you want to call the “flows/trigger” endpoint (Cars.co.za style),
# set EVOLVESA_LEAD_TRIGGER_URL to the full URL (including did=...).
# EVOLVESA_LEAD_TRIGGER_URL=https://portal-admin.evolvesa.co.za/flows/trigger/<trigger-id>?did=505
# EVOLVESA_LEAD_RECEIVING_ENTITY_ID=505
# EVOLVESA_LEAD_RECEIVING_ENTITY_NAME=LDC
# EVOLVESA_LEAD_SOURCE=CubeOneScan
# EVOLVESA_LEAD_SOURCE_ID=236
# EVOLVESA_STOCK_SOURCE=CubeOneScan
# EVOLVESA_STOCK_SOURCE_ID=236
# EVOLVESA_DEFAULT_LEAD_ANCILLARY_AREA=Gauteng
# EVOLVESA_DEFAULT_LEAD_USER_AREA=JHB
# Optional stock trigger URL (preferred over API stock endpoint when provided):
# EVOLVESA_STOCK_TRIGGER_URL=https://portal-admin.evolvesa.co.za/flows/trigger/<stock-trigger-id>?did=509
# EVOLVESA_STOCK_ENDPOINT=/api/v1/stocks

# Optional tenant stamping: set this to cubeone-auth JWT_SECRET
# so connector can verify X-User-Token and stamp dealer/branch/user context.
# AUTH_JWT_SECRET=your_auth_jwt_secret

# AutoTrader syndication listings API (optional; used to auto-attach photo URLs for SEND_STOCK_TO_LEAD)
# AUTOTRADER_LISTINGS_URL=https://services.autotrader.co.za/api/syndication/v1.0/listings
# AUTOTRADER_BASIC_AUTH=Basic base64(username:password)
# AUTOTRADER_TIMEOUT_MS=12000
# AUTOTRADER_LISTINGS_CACHE_TTL_MS=300000

